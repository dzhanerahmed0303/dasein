---
import Card from "./Card.astro";
import { getCollection } from 'astro:content';
import { withBase } from '../utils/slugify';

export interface Props {
    heading?: string;
    limit?: number;
    viewAllHref?: string;
    viewAllLabel?: string;
}

const {
    heading = "Projects",
    limit = 4,
    viewAllHref = '/projects/',
    viewAllLabel = "View all projects",
} = Astro.props as Props;

const allProjects = (await getCollection("projects")).sort(
    (a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0),
);

const visibleItems = allProjects.slice(0, limit);

const baseUrl =
    !import.meta.env.BASE_URL || import.meta.env.BASE_URL === "/"
        ? ""
        : import.meta.env.BASE_URL;
---

<section>
    <div class="max-w-[90rem] mx-auto pt-8 px-8">
        <div
            class="grid grid-cols-1 gap-y-8 md:gap-y-16 md:grid-cols-3 border-b py-8 md:py-16 lg:py-24 border-base-200"
        >
            <div class="lg:sticky lg:top-24 lg:z-40 self-start">
                <h2 class="text-sm 2xl:text-xl text-base-900 font-bold uppercase">
                    {heading}
                </h2>
            </div>

            <div class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-y-8 md:gap-y-12 lg:gap-y-16 gap-x-6 md:gap-x-8">
                {visibleItems.map((project, i) => (
                    <div data-reveal style={`transition-delay:${i * 100}ms`}>
                        <Card
                            title={project.data.title}
                            href={withBase(`/projects/${project.id}/`)}
                            description={project.data.description}
                        />
                    </div>
                ))}
                <div data-reveal style={`transition-delay:${visibleItems.length * 100}ms`}>
                    <Card
                        title={viewAllLabel}
                        href={`${baseUrl}${viewAllHref}`}
                    />
                </div>
            </div>
        </div>
    </div>
</section>
