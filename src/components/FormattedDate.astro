---
const { date, pubDate, updatedDate } = Astro.props;

const raw = date ?? pubDate ?? updatedDate;
const d = raw ? new Date(raw) : null;
---

{d ? (
  <time datetime={d.toISOString()}>
    {d.toLocaleDateString('en-us', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })}
  </time>
) : (
  <time>Unknown date</time>
)}
